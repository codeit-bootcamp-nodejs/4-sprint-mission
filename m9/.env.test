# =========================
# DATABASE (TEST)
# =========================
DATABASE_URL="file:./test.db"

# =========================
# JWT (TEST)
# =========================
JWT_ACCESS_TOKEN_SECRET="test_access_secret_key_for_testing_only"
JWT_REFRESH_TOKEN_SECRET="test_refresh_secret_key_for_testing_only"
JWT_ACCESS_TOKEN_COOKIE_NAME="accessToken"
JWT_REFRESH_TOKEN_COOKIE_NAME="refreshToken"
JWT_ACCESS_TOKEN_EXPIRES_IN="1h"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"

# =========================
# SESSION (TEST)
# =========================
SESSION_SECRET="test_session_secret_for_testing_only"

# =========================
# SERVER (TEST)
# =========================
PORT=3001
NODE_ENV="test"

# =========================
# FILE UPLOAD (TEST)
# =========================
UPLOAD_PATH="./uploads/test"
MAX_FILE_SIZE=5242880
