datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  price       Int
  tags        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
}

model Article {
  id       Int     @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model comment {
  id       Int     @id @default(autoincrement())
  content    String
  createdAt DateTime @default(now())
  productId  Int?     
  articleId  Int?
}

