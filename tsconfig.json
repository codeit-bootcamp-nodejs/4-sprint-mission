{
  "compilerOptions": {
    "target": "ES2020", 
    "module": "NodeNext",
    "lib": ["ES2020"], 
    "baseUrl": ".", 
    "outDir": "./dist",
    "rootDir": "./src", 
    "strict": true,
    "noImplicitAny": true, 
    "strictNullChecks": true, 
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true, 
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true 
  },
  "include": ["src/**/*"], 
  "exclude": ["node_modules", "dist"] 
}