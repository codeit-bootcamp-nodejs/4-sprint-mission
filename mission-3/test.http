// Product tests

### 상품 목록 조회
GET http://localhost:3000/product?page=0&keyword=&nums=

### 상품 단건 조회
GET http://localhost:3000/product/7

### 상품 생성
POST http://localhost:3000/product
Content-Type: application/json

{
  "name": "게이밍 마우스",
  "description": "초정밀 센서 탑재",
  "price": 55000,
  "tags": ["gaming", "mouse", "sensor"]
}

### 상품 수정
PATCH http://localhost:3000/product/13
Content-Type: application/json

{
  "price": 59900,
  "tags": ["gaming", "mouse", "RGB"]
}

### 상품 삭제
DELETE http://localhost:3000/product/13

// Article tests

### 게시글 목록 조회
GET http://localhost:3000/article?page=0&keyword=

### 게시글 단건 조회
GET http://localhost:3000/article/3

### 게시글 생성
POST http://localhost:3000/article
Content-Type: application/json

{
  "title": "Express와 Prisma를 활용하여 api 만들기",
  "content": "이 게시글은 테스트용입니다."
}

### 게시글 수정
PATCH http://localhost:3000/article/9
Content-Type: application/json

{
  "title": "게시글 수정하기",
  "content": "내용을 수정 했습니다."
}

### 게시글 삭제
DELETE http://localhost:3000/article/10

### 게시글 댓글 작성
POST http://localhost:3000/article/3/comment
Content-Type: application/json

{
  "content": "이 게시글에 대한 첫 댓글입니다!"
}

### 게시글 댓글 목록 조회
GET http://localhost:3000/article/3/comment?page=0&cursorId=3

### 게시글 댓글 수정
PATCH http://localhost:3000/article/3/comment/3
Content-Type: application/json

{
  "content": "댓글 내용을 수정했습니다."
}

### 게시글 댓글 삭제
DELETE http://localhost:3000/article/3/comment/10

### 상품 댓글 작성
POST http://localhost:3000/product/3/comment
Content-Type: application/json

{
  "content": "이 상품 정말 좋아요!"
}

### 상품 댓글 목록 조회
GET http://localhost:3000/product/3/comment?cursorId=3

### 상품 댓글 수정
PATCH http://localhost:3000/product/3/comment/6
Content-Type: application/json

{
  "content": "댓글 내용을 수정해봤어요."
}

### 상품 댓글 삭제
DELETE http://localhost:3000/product/3/comment/11

### 파일 업로드 테스트
POST http://localhost:3000/uploads
Content-Type: multipart/form-data; boundary=Boundary01234567890123456789

--Boundary01234567890123456789
Content-Disposition: form-data; name="image"; filename="profile.txt"
Content-Type: text/plain

This is profile image.
--Boundary01234567890123456789--

### 이미지 파일 업로드 테스트
POST http://localhost:3000/uploads
Content-Type: multipart/form-data; boundary=Boundary01234567890123456789

--Boundary01234567890123456789
Content-Disposition: form-data; name="image"; filename="testdog.png"
Content-Type: image/png

< ./testdog.png
--Boundary01234567890123456789--

